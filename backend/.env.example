DATABASE_URL=postgres://educonnect:educonnect@localhost:55432/educonnect_lms?sslmode=disable
JWT_SECRET=change-me-in-production
PORT=8080
# US1.7: chỉ bật "true" ở dev/seed dữ liệu demo để tạo được tài khoản
# teacher/admin qua API đăng ký công khai. Production PHẢI để "false" —
# đăng ký công khai luôn tạo Student, nâng cấp Giảng viên phải qua Admin duyệt.
ALLOW_ROLE_ON_REGISTER=false
# Gmail SMTP dùng App Password (myaccount.google.com/apppasswords), không dùng mật khẩu Gmail thật
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-16-char-app-password
SMTP_FROM=your-email@gmail.com
